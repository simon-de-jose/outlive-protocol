# === Required ===
HEALTH_DATA_DIR=~/health-data

# === Optional (defaults derived from HEALTH_DATA_DIR) ===
# HEALTH_DB_PATH=~/health-data/health.duckdb
# HEALTH_LOG_DIR=~/health-data/logs
# HEALTH_REPORTS_DIR=~/health-data/reports

# === Display ===
# HEALTH_OWNER=YourName
# HEALTH_UNITS=metric    # metric | imperial

# === sync-health-data skill ===
# HEALTH_ICLOUD_FOLDER=~/Library/Mobile Documents/com~apple~CloudDocs/Health Data
# LIBRE_CSV_PREFIX=

# === Upload server (sync-health-data) ===
# HEALTH_UPLOAD_PORT=8766
# HEALTH_UPLOAD_TOKEN=
# HEALTH_UPLOAD_DIR=          # defaults to HEALTH_ICLOUD_FOLDER

# === log-nutrition skill ===
USDA_API_KEY=your_api_key_here

# === coach-strength skill ===
HEVY_API_KEY=your_hevy_api_key_here
